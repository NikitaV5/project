// SYSTEM CHECKLIST
// ============================================================
function populateSystemChecklist() {
  const oaiKey = localStorage.getItem('underrubbl_openai_key');
  const orKey  = localStorage.getItem('underrubbl_ds_key');
  const hasKey = !!(oaiKey || orKey);
  const checks = [
    { name: 'ACOUSTIC BEACON',  status: 'ok',                                                                                    note: 'Ready — 4000Hz SOS' },
    { name: 'MEDICAL ID',       status: (survivorData.blood && survivorData.blood !== 'Unknown') ? 'ok' : 'warn',                note: (survivorData.blood && survivorData.blood !== 'Unknown') ? 'Configured' : 'Incomplete' },
    { name: 'AI PSYCHOLOGIST',  status: hasKey ? 'ok' : 'warn',                                                                  note: hasKey ? 'OpenAI connected' : 'No key — fallback mode' },
    { name: 'HAZARD MONITORING',status: 'ok',                                                                                    note: 'USGS feed active' },
    { name: 'WEB AUDIO API',    status: (window.AudioContext || window.webkitAudioContext) ? 'ok' : 'danger',                    note: (window.AudioContext || window.webkitAudioContext) ? 'Available' : 'Not supported' },
    { name: 'BATTERY API',      status: 'getBattery' in navigator ? 'ok' : 'warn',                                              note: 'getBattery' in navigator ? 'Native' : 'Simulated' },
    { name: 'AUTO-SOS (DMS)',   status: dmsEnabled ? 'ok' : 'warn',                                                             note: dmsEnabled ? `Armed — ${dmsTimeoutMinutes}m timeout` : 'Disabled' },
  ];
  const container = document.getElementById('sys-checklist');
  if (!container) return;
  container.innerHTML = checks.map(c => `
    <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 10px;background:var(--surface2);border-radius:6px;border:1px solid var(--border);">
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="status-dot ${c.status}"></div>
        <span style="font-family:var(--font-display);font-size:10px;letter-spacing:0.1em;">${c.name}</span>
      </div>
      <span style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);">${c.note}</span>
    </div>
  `).join('');
}

// ============================================================
// HAZARD MONITORING
// ============================================================
async function fetchHazardData() { await fetchEarthquakes(); generateWeatherThreats(); }

async function fetchEarthquakes() {
  const container = document.getElementById('quake-list');
  try {
    const res  = await fetch('https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/significant_week.geojson');
    const data = await res.json();
    const quakes = data.features.slice(0, 5);
    if (quakes.length === 0) {
      container.innerHTML = `<div class="alert-card safe"><div style="font-family:var(--font-display);font-size:11px;color:var(--green);letter-spacing:0.1em;">NO SIGNIFICANT EVENTS</div><div style="font-size:12px;color:var(--text-dim);margin-top:4px;">No significant earthquakes in past 7 days (USGS)</div></div>`;
    } else {
      container.innerHTML = quakes.map(q => {
        const mag = q.properties.mag, place = q.properties.place;
        const time = new Date(q.properties.time).toLocaleString();
        const sev  = mag >= 6.5 ? 'danger' : mag >= 5.5 ? 'moderate' : 'safe';
        const lab  = mag >= 6.5 ? 'MAJOR' : mag >= 5.5 ? 'MODERATE' : 'MINOR';
        return `<div class="alert-card ${sev}"><div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;"><span class="tag tag-${sev==='danger'?'red':sev==='moderate'?'amber':'green'}">${lab}</span><span style="font-family:var(--font-display);font-size:13px;font-weight:700;color:var(--amber);">M${mag.toFixed(1)}</span></div><div style="font-size:12px;color:var(--text);margin-bottom:2px;">${place}</div><div style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);">${time}</div></div>`;
      }).join('');
    }
    document.getElementById('quake-updated').textContent = 'Last updated: ' + new Date().toLocaleTimeString();
  } catch(e) {
    container.innerHTML = `<div class="alert-card moderate"><div style="font-family:var(--font-display);font-size:11px;color:var(--amber);">USGS FEED UNAVAILABLE</div><div style="font-size:12px;color:var(--text-dim);margin-top:4px;">Check connection.</div></div>`;
    document.getElementById('quake-updated').textContent = 'USGS unreachable';
  }
}

