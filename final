<script>
// ============================================================
// STATE
// ============================================================
let survivorData = {};
let sosActive = false;
let audioCtx = null;
let sosOscillators = [];
let sosPulseInterval = null;
let waveAnimFrame = null;
let breathRunning = false;
let currentPhaseIdx = 0;
let currentSecond = 4;
let breathInterval = null;
let chatHistory = [];

let dmsEnabled = true;
let dmsTimeoutMinutes = 10;
let dmsTimer = null;
let dmsCountdownTimer = null;
let dmsCountdownVal = 10;
let lastActivity = Date.now();
let dmsBarInterval = null;

// ============================================================
// SYSTEM PROMPT
// ============================================================
const AI_SYSTEM_PROMPT = `You are Dr. Aria — crisis psychologist inside an emergency survival app. User may be trapped, injured, or in shock.

RULES (non-negotiable):
- 2–3 sentences MAX. No exceptions.
- First sentence: name the emotion or situation directly. No "I understand" or "I hear you".
- Second sentence: ONE concrete physical action (not advice, not explanation — action).
- Third sentence (optional): one grounding question or next step.
- NEVER: "it's okay", "don't worry", "I'm here for you", filler phrases, repeating previous advice.
- Language: auto-detect and match (Ukrainian/Russian/English).
- Injury/danger: prioritize first aid and energy conservation over psychology.
- Vary structure every reply — never open the same way twice.
- Build on conversation history. If you already gave breathing advice — don't repeat it.

Survivor: Name=${survivorData?.name}, Blood=${survivorData?.blood}, Age=${survivorData?.age}, Allergies=${survivorData?.allergies}, Meds=${survivorData?.meds}

RESPOND LIKE A FIELD MEDIC WHO ALSO KNOWS CBT. TERSE. DIRECT. ACTIONABLE.`;

// ============================================================
// INIT
// ============================================================
function initApp() {
