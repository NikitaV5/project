function addInitialChatMessage() {
  const name = (survivorData.name && survivorData.name !== 'Unknown') ? survivorData.name : 'Survivor';
  appendAIMessage(`${name}, I'm Dr. Aria. I'm here with you right now. Take one slow breath — in through your nose, out through your mouth. What's your most immediate need right now?`);
}

function appendAIMessage(text) {
  const container = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = 'chat-bubble ai';
  div.textContent = text;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
  chatHistory.push({ role: 'assistant', content: text });
  speakText(text);
}

function appendUserMessage(text) {
  const container = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = 'chat-bubble user';
  div.textContent = text;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
  chatHistory.push({ role: 'user', content: text });
}

function speakText(text) {
  try {
    if (!('speechSynthesis' in window) || !text) return;
    window.speechSynthesis.cancel();
    const utter = new SpeechSynthesisUtterance(text);
    utter.rate = 0.92; utter.pitch = 1.0;
    const lang = navigator.language || '';
    if (lang.startsWith('uk')) utter.lang = 'uk-UA';
    else if (lang.startsWith('ru')) utter.lang = 'ru-RU';
    else utter.lang = 'en-US';
    window.speechSynthesis.speak(utter);
  } catch(e) {}
}

async function sendChat() {
  const input = document.getElementById('chat-input');
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';
  await processMessage(msg);
}

async function sendQuickMsg(msg) {
  switchTab('ai');
  await processMessage(msg);
}

async function processMessage(msg) {
  appendUserMessage(msg);
  document.getElementById('ai-loading').style.display = 'block';
  document.getElementById('chat-messages').scrollTop = 9999;

  const oaiKey = localStorage.getItem('underrubbl_openai_key');
  const orKey  = localStorage.getItem('underrubbl_ds_key');

  try {
    let reply = '';
    if (oaiKey) {
      reply = await callOpenAI(oaiKey);
    } else if (orKey) {
      reply = await callOpenRouter(orKey);
    }
    document.getElementById('ai-loading').style.display = 'none';
    if (reply) { appendAIMessage(reply); return; }
  } catch(e) {
    console.warn('AI call failed:', e.message);
  }

  document.getElementById('ai-loading').style.display = 'none';
  appendAIMessage(getContextualFallback(msg));
}

async function callOpenAI(key) {
  const model  = localStorage.getItem('underrubbl_openai_model') || 'gpt-4o-mini';
  const apiKey = key || localStorage.getItem('underrubbl_openai_key');
  if (!apiKey) throw new Error('No OpenAI key');

  const systemWithContext = AI_SYSTEM_PROMPT +
    `\n\nSurvivor profile: Name=${survivorData.name || 'Unknown'}, Blood=${survivorData.blood || 'Unknown'}, Age=${survivorData.age || 'Unknown'}, Allergies=${survivorData.allergies || 'None'}, Meds=${survivorData.meds || 'None'}.`;

  const messages = chatHistory.slice(-20);

  const res = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + apiKey },
    body: JSON.stringify({
      model,
      max_tokens: 300,
      temperature: 1.0,
      presence_penalty: 0.8,
      frequency_penalty: 0.6,
      messages: [
        { role: 'system', content: systemWithContext },
        ...messages
      ]
    })
  });

  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error((err.error && err.error.message) ? err.error.message : 'API error ' + res.status);
  }
  const data = await res.json();
  return data.choices?.[0]?.message?.content || '';
}

async function callOpenRouter(key) {
  const systemWithContext = AI_SYSTEM_PROMPT +
    `\n\nSurvivor profile: Name=${survivorData.name || 'Unknown'}, Blood=${survivorData.blood || 'Unknown'}, Age=${survivorData.age || 'Unknown'}.`;
  const messages = chatHistory.slice(-20);

  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + key },
    body: JSON.stringify({
      model: 'openai/gpt-4o-mini',
      max_tokens: 300,
      temperature: 1.0,
      presence_penalty: 0.8,
      frequency_penalty: 0.6,
      messages: [
        { role: 'system', content: systemWithContext },
        ...messages
      ]
    })
  });
  if (!res.ok) throw new Error('API ' + res.status);
  const data = await res.json();
  return data.choices?.[0]?.message?.content || '';
}

function getContextualFallback(msg) {
  const m = (msg || '').toLowerCase();
  if (m.includes('panic') || m.includes('scare') || m.includes('afraid') || m.includes('паніку') || m.includes('страх'))
    return "Your fear makes complete sense right now. Place your hand on your chest — feel it rise and fall. Count to 4 while you breathe in, slowly.";
  if (m.includes('pain') || m.includes('hurt') || m.includes('injur') || m.includes('біль'))
    return "I hear you're in pain. Rate it 1-10 out loud, then press firmly on the most painful spot with any fabric you can find and hold steady pressure.";
  if (m.includes('breath') || m.includes('breathe') || m.includes('air') || m.includes('дих'))
    return "You have enough air. Put one hand on your belly — push it OUT as you breathe in. That engages your diaphragm and slows your nervous system down.";
  if (m.includes('help') || m.includes('rescue') || m.includes('save'))
    return "Rescuers are moving toward you right now. Save your voice — instead, tap rhythmically on any metal pipe you can reach: three short, three long, three short.";
  if (m.includes('water') || m.includes('thirst'))
    return "The body is remarkably resilient — 3 days without water is survivable. Breathe slowly through your nose; it reduces moisture loss significantly.";
  if (m.includes('hopeless') || m.includes('give up') || m.includes('alone') || m.includes('надія'))
    return "You reached out — that means part of you is still fighting. Think of one person waiting for you on the outside. Hold that image. Tell me their name.";
  const defaults = [
    "Right now, this second — what does the air around you feel like? Describe it to me.",
    "You're doing better than you realize. Place both palms flat on something solid near you.",
    "Stay still and conserve every bit of energy. What's the one thing that worries you most?",
    "I'm with you. When did you last hear any sound from outside?",
  ];
  return defaults[Math.floor(Math.random() * defaults.length)];
}

