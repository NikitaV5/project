<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#000000">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<title>UnderRubbl Survival OS</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Exo+2:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --amber: #FF9500;
    --amber-dim: #b36900;
    --amber-glow: rgba(255,149,0,0.3);
    --red: #FF3B30;
    --red-dim: #8b1f19;
    --red-glow: rgba(255,59,48,0.3);
    --green: #30D158;
    --blue: #0A84FF;
    --bg: #000000;
    --surface: #0a0a0a;
    --surface2: #111111;
    --surface3: #1a1a1a;
    --border: rgba(255,149,0,0.15);
    --text: #e8e0d0;
    --text-dim: #7a7060;
    --font-mono: 'Share Tech Mono', monospace;
    --font-display: 'Orbitron', sans-serif;
    --font-body: 'Exo 2', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    min-height: 100vh;
    min-height: 100dvh;
    overflow-x: hidden;
  }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events: none;
    z-index: 9999;
  }
  .tactical-box {
    position: relative;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .tactical-box::before, .tactical-box::after {
    content: '';
    position: absolute;
    width: 12px; height: 12px;
    border-color: var(--amber);
    border-style: solid;
  }
  .tactical-box::before { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
  .tactical-box::after  { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }
  .font-mono { font-family: var(--font-mono); }
  .font-display { font-family: var(--font-display); }
  .nav-tab {
    font-family: var(--font-display);
    font-size: 10px;
    letter-spacing: 0.1em;
    padding: 10px 6px 8px;
    color: var(--text-dim);
    border-top: 2px solid transparent;
    transition: all 0.2s;
    cursor: pointer;
    flex: 1;
    text-align: center;
    user-select: none;
    background: none;
    border-left: none; border-right: none; border-bottom: none;
  }
  .nav-tab.active {
    color: var(--amber);
    border-top-color: var(--amber);
    background: rgba(255,149,0,0.05);
  }
  .nav-tab svg { margin: 0 auto 4px; display: block; }
  .panel { display: none; }
  .panel.active { display: block; }
  .sos-btn {
    width: 160px; height: 160px;
    border-radius: 50%;
    border: 3px solid var(--red);
    background: radial-gradient(circle, rgba(255,59,48,0.15) 0%, rgba(255,59,48,0.03) 70%);
    color: var(--red);
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 900;
    letter-spacing: 0.15em;
    cursor: pointer;
    position: relative;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 20px rgba(255,59,48,0.2), inset 0 0 30px rgba(255,59,48,0.05);
  }
  .sos-btn:active { transform: scale(0.95); }
  .sos-btn.active {
    background: radial-gradient(circle, rgba(255,59,48,0.3) 0%, rgba(255,59,48,0.1) 70%);
    box-shadow: 0 0 40px rgba(255,59,48,0.5), 0 0 80px rgba(255,59,48,0.2), inset 0 0 30px rgba(255,59,48,0.1);
  }
  .pulse-ring {
    position: absolute;
    border-radius: 50%;
    border: 2px solid var(--red);
    opacity: 0;
    animation: none;
  }
  .sos-btn.active .pulse-ring:nth-child(1) { width: 180px; height: 180px; animation: pulseOut 2s ease-out infinite 0s; }
  .sos-btn.active .pulse-ring:nth-child(2) { width: 210px; height: 210px; animation: pulseOut 2s ease-out infinite 0.5s; }
  .sos-btn.active .pulse-ring:nth-child(3) { width: 240px; height: 240px; animation: pulseOut 2s ease-out infinite 1s; }
  @keyframes pulseOut { 0% { transform: scale(0.85); opacity: 0.8; } 100% { transform: scale(1); opacity: 0; } }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
  .blink { animation: blink 1s step-end infinite; }
  .text-amber { color: var(--amber); }
  .text-red { color: var(--red); }
  .text-green { color: var(--green); }
  .battery-bar {
    height: 8px;
    background: var(--surface3);
    border-radius: 4px;
    overflow: hidden;
  }
  .battery-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 1s ease, background 0.5s;
  }
  #chat-messages {
    height: 280px;
    overflow-y: auto;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--amber-dim) transparent;
  }
  #chat-messages::-webkit-scrollbar { width: 4px; }
  #chat-messages::-webkit-scrollbar-thumb { background: var(--amber-dim); border-radius: 2px; }
  .chat-bubble {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 10px;
    animation: fadeUp 0.3s ease;
  }
  .chat-bubble.ai {
    background: var(--surface3);
    border: 1px solid var(--border);
    border-bottom-left-radius: 4px;
    color: var(--text);
  }
  .chat-bubble.user {
    background: rgba(255,149,0,0.12);
    border: 1px solid rgba(255,149,0,0.25);
    border-bottom-right-radius: 4px;
    color: var(--amber);
    margin-left: auto;
  }
  .typing-indicator span {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--text-dim);
    margin: 0 2px;
    animation: bounce 1.2s infinite;
  }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-6px)} }
  @keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  #breath-circle {
    width: 100px; height: 100px;
    border-radius: 50%;
    border: 2px solid var(--amber);
    background: radial-gradient(circle, rgba(255,149,0,0.1), transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 10px;
    color: var(--amber);
    letter-spacing: 0.05em;
    text-align: center;
    transition: transform 0.5s ease;
    flex-shrink: 0;
  }
  #breath-circle.inhale { transform: scale(1.4); }
  #breath-circle.hold   { transform: scale(1.4); }
  #breath-circle.exhale { transform: scale(1); }
  .alert-card {
    border-left: 3px solid var(--red);
    background: rgba(255,59,48,0.05);
    padding: 10px 14px;
    border-radius: 0 8px 8px 0;
    margin-bottom: 10px;
    animation: fadeUp 0.4s ease;
  }
  .alert-card.moderate { border-left-color: var(--amber); background: rgba(255,149,0,0.05); }
  .alert-card.safe { border-left-color: var(--green); background: rgba(48,209,88,0.05); }
  .tactical-input {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 14px;
    padding: 10px 14px;
    width: 100%;
    outline: none;
    transition: border-color 0.2s;
  }
  .tactical-input:focus { border-color: var(--amber); box-shadow: 0 0 0 2px var(--amber-glow); }
  .tactical-input::placeholder { color: var(--text-dim); }
  select.tactical-input option { background: #111; }
  .btn-amber {
    background: transparent;
    border: 1px solid var(--amber);
    color: var(--amber);
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.1em;
    padding: 10px 20px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .btn-amber:hover, .btn-amber:active { background: rgba(255,149,0,0.1); }
  .btn-red {
    background: rgba(255,59,48,0.1);
    border: 1px solid var(--red);
    color: var(--red);
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.1em;
    padding: 10px 20px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .btn-red:active { background: rgba(255,59,48,0.25); }
  /* ── FIXED: btn-red hover state for visibility ── */
  .btn-red:hover { background: rgba(255,59,48,0.2); box-shadow: 0 0 12px rgba(255,59,48,0.3); }
  .signal-bar { width: 6px; background: var(--surface3); border-radius: 2px; transition: background 0.5s; }
  .signal-bar.active { background: var(--green); }
  #waveform { display: flex; align-items: center; gap: 3px; height: 40px; }
  .wave-bar { width: 4px; background: var(--amber); border-radius: 2px; transition: height 0.1s; }
  .status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
  .status-dot.ok     { background: var(--green); box-shadow: 0 0 6px var(--green); }
  .status-dot.warn   { background: var(--amber); box-shadow: 0 0 6px var(--amber); animation: blink 1s infinite; }
  .status-dot.danger { background: var(--red);   box-shadow: 0 0 6px var(--red);   animation: blink 0.5s infinite; }
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--amber-dim); border-radius: 2px; }
  .section-header {
    font-family: var(--font-display);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-header::after { content:''; flex:1; height:1px; background: var(--border); }
  .grid-bg {
    background-image:
      linear-gradient(rgba(255,149,0,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,149,0,0.03) 1px, transparent 1px);
    background-size: 30px 30px;
  }
  .quick-action {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 8px 16px;
    font-size: 12px;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    font-family: var(--font-body);
  }
  .quick-action:hover, .quick-action:active { border-color: var(--amber); color: var(--amber); background: rgba(255,149,0,0.05); }
  #onboard-overlay {
    position: fixed; inset: 0; z-index: 10000;
    background: rgba(0,0,0,0.97);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 24px;
  }
  @keyframes glitch {
    0%,100% { text-shadow: 2px 0 var(--red), -2px 0 var(--blue); }
    25% { text-shadow: -2px 0 var(--red), 2px 0 var(--blue); }
    50% { text-shadow: 2px 2px var(--red), -2px -2px var(--blue); }
    75% { text-shadow: -2px 2px var(--amber), 2px -2px var(--blue); }
  }
  .glitch { animation: glitch 3s infinite; }
  .tag { font-family: var(--font-mono); font-size: 10px; padding: 2px 6px; border-radius: 3px; letter-spacing: 0.05em; }
  .tag-red   { background: rgba(255,59,48,0.15); color: var(--red);   border: 1px solid rgba(255,59,48,0.3); }
  .tag-amber { background: rgba(255,149,0,0.15); color: var(--amber); border: 1px solid rgba(255,149,0,0.3); }
  .tag-green { background: rgba(48,209,88,0.15); color: var(--green); border: 1px solid rgba(48,209,88,0.3); }
  @keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
  .shimmer {
    background: linear-gradient(90deg, var(--surface2) 25%, var(--surface3) 50%, var(--surface2) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 4px;
  }
  *:focus-visible { outline: 2px solid var(--amber); outline-offset: 2px; border-radius: 4px; }

  .api-key-box {
    background: rgba(255,149,0,0.06);
    border: 1px solid rgba(255,149,0,0.4);
    border-radius: 10px;
    padding: 16px;
    margin-bottom: 14px;
    position: relative;
  }
  .api-key-box::before {
    content: '🔑 OPENAI KEY';
    font-family: var(--font-display);
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--amber);
    display: block;
    margin-bottom: 10px;
  }
  .api-key-input-row {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }
  .api-key-input-row input {
    flex: 1;
    background: #000;
    border: 1px solid rgba(255,149,0,0.5);
    border-radius: 8px;
    color: var(--amber);
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 12px 14px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .api-key-input-row input:focus {
    border-color: var(--amber);
    box-shadow: 0 0 0 3px var(--amber-glow);
  }
  .api-key-input-row input::placeholder { color: #4a3f2a; }
  .btn-save-key {
    background: var(--amber);
    border: none;
    color: #000;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 12px 16px;
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }
  .btn-save-key:hover { background: #ffaa22; }
  .key-status-banner {
    margin-top: 10px;
    padding: 8px 12px;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    display: flex;
    align-items: center;
    gap: 8px;
    min-height: 34px;
  }
  .key-status-banner.saved {
    background: rgba(48,209,88,0.1);
    border: 1px solid rgba(48,209,88,0.3);
    color: var(--green);
  }
  .key-status-banner.empty {
    background: rgba(255,149,0,0.05);
    border: 1px solid rgba(255,149,0,0.2);
    color: var(--text-dim);
  }
  .key-status-banner.error {
    background: rgba(255,59,48,0.08);
    border: 1px solid rgba(255,59,48,0.3);
    color: var(--red);
  }

  /* ══ DEAD MAN'S SWITCH OVERLAY — FIXED ══ */
  #dms-overlay {
    position: fixed;
    inset: 0;
    z-index: 20000;
    background: rgba(0,0,0,0.98);
    /* Changed: use visibility+opacity instead of display:none so transition works,
       but keep display:flex always so flexbox centering works */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px;
    text-align: center;
    /* Hidden by default via pointer-events + opacity */
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  #dms-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }
  @keyframes dmsPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(255,59,48,0.7); }
    50%      { box-shadow: 0 0 0 30px rgba(255,59,48,0); }
  }
  .dms-ring {
    width: 140px; height: 140px;
    border-radius: 50%;
    border: 3px solid var(--red);
    display: flex; align-items: center; justify-content: center;
    animation: dmsPulse 1s ease infinite;
    margin-bottom: 24px;
  }
  #dms-countdown {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 900;
    color: var(--red);
    line-height: 1;
  }
  .toggle-switch {
    width: 44px; height: 24px;
    background: var(--surface3);
    border-radius: 12px;
    position: relative;
    cursor: pointer;
    border: 1px solid var(--border);
    transition: background 0.3s;
    flex-shrink: 0;
  }
  .toggle-switch.on { background: var(--amber); }
  .toggle-switch::after {
    content: '';
    position: absolute;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--text);
    top: 2px; left: 2px;
    transition: left 0.3s;
  }
  .toggle-switch.on::after { left: 22px; }
  .battery-big-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 180px;
    height: 180px;
  }
  .battery-big-wrap svg { transform: rotate(-90deg); }
  .battery-ring-bg { fill: none; stroke: var(--surface3); stroke-width: 10; }
  .battery-ring-fill { fill: none; stroke-width: 10; stroke-linecap: round; transition: stroke-dashoffset 1s ease, stroke 0.5s; }
  .battery-big-text {
    position: absolute;
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 900;
    color: var(--amber);
    text-align: center;
    line-height: 1;
  }
  .dms-sys-bar {
    width: 100%;
    height: 6px;
    background: var(--surface3);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 10px;
  }
  .dms-sys-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--amber);
    transition: width 1s linear;
  }

  /* ── DMS Test button — extra prominent ── */
  #dms-test-btn {
    width: 100%;
    margin-top: 12px;
    padding: 14px 20px;
    font-size: 11px;
    letter-spacing: 0.15em;
    background: rgba(255,59,48,0.12);
    border: 1px solid var(--red);
    color: var(--red);
    font-family: var(--font-display);
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    position: relative;
    overflow: hidden;
  }
  #dms-test-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,59,48,0.15), transparent);
    transform: translateX(-100%);
    transition: transform 0.4s ease;
  }
  #dms-test-btn:hover { background: rgba(255,59,48,0.22); box-shadow: 0 0 16px rgba(255,59,48,0.35); }
  #dms-test-btn:hover::before { transform: translateX(100%); }
  #dms-test-btn:active { transform: scale(0.98); background: rgba(255,59,48,0.3); }
</style>
</head>
<body class="grid-bg">

<!-- ══ DEAD MAN'S SWITCH OVERLAY — FIXED ══ -->
<div id="dms-overlay" role="alertdialog" aria-modal="true" aria-labelledby="dms-title">
  <div class="dms-ring">
    <div id="dms-countdown">10</div>
  </div>
  <h2 id="dms-title" style="font-family:var(--font-display);font-size:18px;color:var(--red);letter-spacing:0.15em;margin-bottom:12px;">⚠ DEAD MAN'S SWITCH</h2>
  <p style="font-family:var(--font-mono);font-size:12px;color:var(--text-dim);margin-bottom:8px;">No activity detected for <span id="dms-timeout-display">10</span> minutes.</p>
  <p style="font-family:var(--font-mono);font-size:11px;color:#555;margin-bottom:28px;">SOS beacon + emergency call will activate automatically.</p>
  <button id="dms-cancel-btn" style="background:var(--red);border:none;color:#fff;font-family:var(--font-display);font-size:14px;letter-spacing:0.1em;padding:18px 40px;border-radius:8px;cursor:pointer;width:100%;max-width:320px;box-shadow:0 0 30px rgba(255,59,48,0.4);">✋ I'M ALIVE — CANCEL</button>
  <p style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);margin-top:16px;" id="dms-sms-status"></p>
</div>

<!-- Onboarding Overlay -->
<div id="onboard-overlay">
  <div style="max-width:380px;width:100%;">
    <div style="text-align:center;margin-bottom:32px;">
      <div style="font-family:var(--font-display);font-size:11px;letter-spacing:0.3em;color:var(--red);margin-bottom:12px;" class="blink">▶ SYSTEM INITIALIZING</div>
      <h1 style="font-family:var(--font-display);font-size:28px;font-weight:900;color:var(--amber);letter-spacing:0.05em;" class="glitch">UNDERRUBBL</h1>
      <div style="font-family:var(--font-display);font-size:10px;letter-spacing:0.3em;color:var(--text-dim);margin-top:4px;">SURVIVAL OS v2.5</div>
      <div style="width:60px;height:1px;background:var(--amber);margin:16px auto;opacity:0.4;"></div>
      <p style="font-size:13px;color:var(--text-dim);line-height:1.6;">Critical medical information. First responders will use this data.</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:24px;">
      <div>
        <label style="font-family:var(--font-display);font-size:9px;letter-spacing:0.15em;color:var(--text-dim);display:block;margin-bottom:6px;">SURVIVOR NAME</label>
        <input id="setup-name" class="tactical-input" type="text" placeholder="Full name" autocomplete="name">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <label style="font-family:var(--font-display);font-size:9px;letter-spacing:0.15em;color:var(--text-dim);display:block;margin-bottom:6px;">BLOOD TYPE</label>
          <select id="setup-blood" class="tactical-input">
