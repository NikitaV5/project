// BOX BREATHING
// ============================================================
const BREATH_PHASES = [
  { name: 'INHALE', class: 'inhale', label: 'IN',   seconds: 4 },
  { name: 'HOLD',   class: 'hold',   label: 'HOLD', seconds: 4 },
  { name: 'EXHALE', class: 'exhale', label: 'OUT',  seconds: 4 },
  { name: 'HOLD',   class: 'hold',   label: 'HOLD', seconds: 4 },
];

function startBreathingExercise() {
  document.getElementById('breath-widget').style.display = 'block';
  document.getElementById('breath-widget').scrollIntoView({ behavior: 'smooth' });
}

function toggleBreathing() {
  breathRunning = !breathRunning;
  document.getElementById('breath-toggle-btn').textContent = breathRunning ? '⏸ PAUSE' : '▶ START';
  if (breathRunning) { currentPhaseIdx = 0; runBreathPhase(); }
  else clearInterval(breathInterval);
}

function runBreathPhase() {
  clearInterval(breathInterval);
  const phase = BREATH_PHASES[currentPhaseIdx];
  const circle = document.getElementById('breath-circle');
  circle.className = '';
  setTimeout(() => circle.classList.add(phase.class), 50);
  document.getElementById('breath-phase').textContent = phase.name;
  document.getElementById('breath-label').textContent = phase.label;
  currentSecond = phase.seconds;
  document.getElementById('breath-count').textContent = currentSecond;
  breathInterval = setInterval(() => {
    if (!breathRunning) return;
    currentSecond--;
    document.getElementById('breath-count').textContent = currentSecond;
    if (currentSecond <= 0) {
      clearInterval(breathInterval);
      currentPhaseIdx = (currentPhaseIdx + 1) % BREATH_PHASES.length;
      runBreathPhase();
    }
  }, 1000);
}

// ============================================================
// VOICE INPUT
// ============================================================
let voiceRecognition = null;
let voiceListening = false;
let voiceWaveAnim = null;

function toggleVoiceInput() {
  if (voiceListening) { stopVoiceInput(); return; }
  startVoiceInput();
}

function startVoiceInput() {
  const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRec) { alert('Speech recognition not supported. Use Chrome or Edge.'); return; }
  if (!voiceRecognition) {
    voiceRecognition = new SpeechRec();
    voiceRecognition.lang = 'uk-UA';
    voiceRecognition.interimResults = true;
    voiceRecognition.maxAlternatives = 1;
    voiceRecognition.continuous = false;
  }
  voiceRecognition.onstart = () => {
    voiceListening = true;
    const btn = document.getElementById('voice-btn');
    if (btn) { btn.textContent = '🎙'; btn.style.background = 'rgba(255,149,0,0.15)'; }
    const bar = document.getElementById('voice-status-bar');
    if (bar) bar.style.display = 'flex';
    startVoiceWave();
  };
  voiceRecognition.onresult = (event) => {
    let t = '';
    for (let i = event.resultIndex; i < event.results.length; i++) t += event.results[i][0].transcript;
    const input = document.getElementById('chat-input');
    if (input && t.trim()) { input.value = t.trim(); document.getElementById('voice-status-txt').textContent = t.trim().substring(0, 40); }
  };
  voiceRecognition.onerror = () => { stopVoiceInput(); };
  voiceRecognition.onend = () => {
    voiceListening = false;
    const btn = document.getElementById('voice-btn');
    if (btn) { btn.textContent = '🎤'; btn.style.background = ''; }
    const bar = document.getElementById('voice-status-bar');
    if (bar) bar.style.display = 'none';
    stopVoiceWave();
    const input = document.getElementById('chat-input');
    if (input && input.value.trim()) sendChat();
  };
  try { voiceRecognition.start(); } catch(e) { stopVoiceInput(); }
}

function stopVoiceInput() {
  if (voiceRecognition) { try { voiceRecognition.stop(); } catch(e){} }
  voiceListening = false;
  const btn = document.getElementById('voice-btn');
  if (btn) { btn.textContent = '🎤'; btn.style.background = ''; }
  const bar = document.getElementById('voice-status-bar');
  if (bar) bar.style.display = 'none';
  stopVoiceWave();
}

function startVoiceWave() {
  let t = 0;
  voiceWaveAnim = setInterval(() => {
    for (let i = 0; i < 5; i++) {
      const el = document.getElementById('vw' + i);
      if (el) el.style.height = (Math.abs(Math.sin(t + i * 0.6)) * 16 + 4) + 'px';
    }
    t += 0.2;
  }, 80);
}

function stopVoiceWave() {
  clearInterval(voiceWaveAnim);
  for (let i = 0; i < 5; i++) { const el = document.getElementById('vw' + i); if (el) el.style.height = '6px'; }
}

