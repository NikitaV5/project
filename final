  document.getElementById('tab-' + tab).classList.add('active');
}

// ============================================================
// BATTERY
// ============================================================
async function initBattery() {
  if ('getBattery' in navigator) {
    try {
      const battery = await navigator.getBattery();
      updateBatteryUI(battery);
      battery.addEventListener('levelchange',    () => updateBatteryUI(battery));
      battery.addEventListener('chargingchange', () => updateBatteryUI(battery));
      return;
    } catch(e) {}
  }
  updateBatteryDisplay(0.72, false, null);
}

function updateBatteryUI(b) { updateBatteryDisplay(b.level, b.charging, b.dischargingTime); }

function updateBatteryDisplay(lvl, charging, dischargingTime) {
  const pct   = Math.round(lvl * 100);
  const color = pct > 50 ? 'var(--green)' : pct > 20 ? 'var(--amber)' : 'var(--red)';
  const mini  = document.getElementById('battery-mini');
  const pctEl = document.getElementById('battery-pct');
  if (mini)  { mini.style.width = pct + '%'; mini.style.background = color; }
  if (pctEl) pctEl.textContent = pct + '%';
  const ring = document.getElementById('battery-ring');
  if (ring)  { ring.style.strokeDashoffset = 471.24 * (1 - lvl); ring.style.stroke = color; }
  const largeEl = document.getElementById('battery-large');
  if (largeEl) { largeEl.textContent = pct + '%'; largeEl.style.color = color; }
  const stateEl = document.getElementById('battery-state');
  if (stateEl) {
    stateEl.textContent = pct <= 15 && !charging ? '⚠ CRITICAL' : charging ? '⚡ CHARGING' : '🔋 DISCHARGING';
    stateEl.style.color = pct <= 15 && !charging ? 'var(--red)' : charging ? 'var(--green)' : 'var(--text-dim)';
  }
  const fillMain = document.getElementById('battery-fill-main');
  if (fillMain) { fillMain.style.width = pct + '%'; fillMain.style.background = color; }
  const cTxt = document.getElementById('battery-charging-txt');
  if (cTxt) { cTxt.textContent = charging ? 'Yes ⚡' : 'No'; cTxt.style.color = charging ? 'var(--green)' : 'var(--text)'; }
  const rEl = document.getElementById('battery-runtime');
  const eEl = document.getElementById('battery-estimate');
  if (dischargingTime && dischargingTime !== Infinity && !charging) {
    const h = Math.floor(dischargingTime / 3600), m = Math.floor((dischargingTime % 3600) / 60);
    if (rEl) rEl.textContent = `~${h}h ${m}m`;
    if (eEl) eEl.textContent = `Estimated ${h}h ${m}m remaining`;
  } else {
    if (rEl) rEl.textContent = charging ? 'Charging' : 'N/A';
    if (eEl) eEl.textContent = '';
  }
}

// ============================================================
// SIGNAL SIMULATION
// ============================================================
function initSignalSimulation() {
  function update() {
    const s = Math.floor(Math.random() * 4) + 1;
    for (let i = 1; i <= 4; i++) document.getElementById('sig' + i).classList.toggle('active', i <= s);
  }
  update(); setInterval(update, 8000);
}

// ============================================================
// SOS BEACON
// ============================================================
function toggleSOS() {
  sosActive = !sosActive;
  const btn = document.getElementById('sos-btn');
  btn.classList.toggle('active', sosActive);
  btn.setAttribute('aria-pressed', sosActive);
  document.getElementById('sos-label').textContent = sosActive ? 'TRANSMITTING' : 'TAP TO ARM';
  document.getElementById('beacon-mode').textContent = sosActive ? 'MODE: ACTIVE' : 'MODE: STANDBY';
  if (sosActive) { startAcousticBeacon(); startWaveAnimation(); }
  else { stopAcousticBeacon(); stopWaveAnimation(); }
}

function getAudioContext() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();
  return audioCtx;
}

const SOS_PATTERN = [200,200,200,200,200,600,600,200,600,200,600,600,200,200,200,200,200,3000];

function startAcousticBeacon() { stopAcousticBeacon(); playSOSPattern(0); }

function playSOSPattern(idx) {
  if (!sosActive) return;
  const ctx = getAudioContext();
  const isDit = idx % 2 === 0;
  const dur   = SOS_PATTERN[idx];
  if (isDit) {
    const osc = ctx.createOscillator(), gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.type = 'sine'; osc.frequency.setValueAtTime(4000, ctx.currentTime);
    gain.gain.setValueAtTime(0.5, ctx.currentTime);
    gain.gain.linearRampToValueAtTime(0, ctx.currentTime + dur / 1000 - 0.01);
    osc.start(ctx.currentTime); osc.stop(ctx.currentTime + dur / 1000);
    sosOscillators.push(osc);
  }
  sosPulseInterval = setTimeout(() => playSOSPattern((idx + 1) % SOS_PATTERN.length), dur);
}

function stopAcousticBeacon() {
  clearTimeout(sosPulseInterval);
  sosOscillators.forEach(o => { try { o.stop(); } catch(e){} });
  sosOscillators = [];
}

function startWaveAnimation() {
  let t = 0;
  function animate() {
    for (let i = 0; i <= 11; i++) {
      const el = document.getElementById('wb' + i);
      if (el) el.style.height = (Math.abs(Math.sin(t + i * 0.5)) * 28 + 4) + 'px';
    }
    t += 0.15; waveAnimFrame = requestAnimationFrame(animate);
  }
  waveAnimFrame = requestAnimationFrame(animate);
}

function stopWaveAnimation() {
  if (waveAnimFrame) cancelAnimationFrame(waveAnimFrame);
  for (let i = 0; i <= 11; i++) { const el = document.getElementById('wb' + i); if (el) el.style.height = '4px'; }
}

// ============================================================
// DEAD MAN'S SWITCH — FIXED
// ============================================================
function initDeadManSwitch() {
  // Wire up the cancel button inside overlay
  document.getElementById('dms-cancel-btn').addEventListener('click', resetDeadManSwitch);

  // Wire up the TEST button — use addEventListener so it can't be overridden by inline onclick
  const testBtn = document.getElementById('dms-test-btn');
  if (testBtn) {
    testBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      triggerDMSWarning();
    });
  }

  ['touchstart','touchend','click','keydown','scroll'].forEach(evt =>
    document.addEventListener(evt, onUserActivity, { passive: true })
  );
  scheduleDMS();
  startDMSBar();
}

function onUserActivity(e) {
  // Don't reset timer if the DMS overlay is visible (user must click the cancel button)
  if (document.getElementById('dms-overlay').classList.contains('visible')) return;
  lastActivity = Date.now();
  scheduleDMS();
}

function scheduleDMS() {
  clearTimeout(dmsTimer);
  if (!dmsEnabled) return;
  dmsTimer = setTimeout(triggerDMSWarning, dmsTimeoutMinutes * 60 * 1000);
}

function startDMSBar() {
  clearInterval(dmsBarInterval);
  dmsBarInterval = setInterval(() => {
    const elapsed = (Date.now() - lastActivity) / 1000;
    const total   = dmsTimeoutMinutes * 60;
    const pct     = Math.min(100, (elapsed / total) * 100);
    const fill  = document.getElementById('dms-bar-fill');
    const label = document.getElementById('dms-bar-label');
    const actEl = document.getElementById('dms-last-activity');
    if (fill)  { fill.style.width = pct + '%'; fill.style.background = pct > 80 ? 'var(--red)' : pct > 50 ? 'var(--amber)' : 'var(--green)'; }
    const em = Math.floor(elapsed / 60), es = Math.floor(elapsed % 60);
    if (label) label.innerHTML = `${em}:${String(es).padStart(2,'0')} / ${dmsTimeoutMinutes} min`;
    document.getElementById('dms-bar-max').textContent = dmsTimeoutMinutes;
    const secs = Math.round(elapsed);
    if (actEl) actEl.textContent = secs < 60 ? `Last activity: ${secs}s ago` : `Last activity: ${Math.round(secs/60)}m ago`;
  }, 1000);
}

function triggerDMSWarning() {
  if (!dmsEnabled) return;
  clearInterval(dmsCountdownTimer); // clear any existing countdown
  dmsCountdownVal = 10;
  document.getElementById('dms-countdown').textContent = dmsCountdownVal;
  document.getElementById('dms-timeout-display').textContent = dmsTimeoutMinutes;
  document.getElementById('dms-sms-status').textContent = '';
  // Show overlay
  document.getElementById('dms-overlay').classList.add('visible');

  dmsCountdownTimer = setInterval(() => {
    dmsCountdownVal--;
    const el = document.getElementById('dms-countdown');
    if (el) el.textContent = dmsCountdownVal;
    if (dmsCountdownVal <= 0) {
      clearInterval(dmsCountdownTimer);
      activateDMS();
    }
  }, 1000);
}

function activateDMS() {
  if (!sosActive) toggleSOS();
  const smsEl = document.getElementById('dms-sms-status');
  if (smsEl) smsEl.textContent = '📞 Opening emergency call (102)...';
  setTimeout(() => { window.location.href = 'tel:102'; }, 1200);
}

function resetDeadManSwitch() {
  clearInterval(dmsCountdownTimer);
  document.getElementById('dms-overlay').classList.remove('visible');
  lastActivity = Date.now();
  scheduleDMS();
}

function toggleDMSSetting() {
  dmsEnabled = !dmsEnabled;
  const btn = document.getElementById('dms-toggle-btn');
  const dot = document.getElementById('dms-dot');
  const lbl = document.getElementById('dms-status-label');
  if (btn) { btn.classList.toggle('on', dmsEnabled); btn.setAttribute('aria-checked', dmsEnabled); }
  if (dot) { dot.style.background = dmsEnabled ? 'var(--green)' : 'var(--amber)'; dot.style.boxShadow = dmsEnabled ? '0 0 6px var(--green)' : '0 0 6px var(--amber)'; }
  if (lbl) lbl.textContent = dmsEnabled ? 'ARMED' : 'DISABLED';
  if (dmsEnabled) scheduleDMS(); else clearTimeout(dmsTimer);
  populateSystemChecklist();
}

function updateDMSTimeout() {
  dmsTimeoutMinutes = parseInt(document.getElementById('dms-timeout-select').value);
  scheduleDMS(); startDMSBar();
}

